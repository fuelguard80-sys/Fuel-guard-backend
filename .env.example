# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Fuel Guard API
APP_ENV=production                      # development | production
API_V1_PREFIX=/api/v1

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-admin-panel.railway.app,https://your-domain.com

# ── Firebase ──────────────────────────────────────────────────────────────────
# PROJECT ID and BUCKET are already set in config.py — only override if needed
FIREBASE_PROJECT_ID=fuelguard-f3112
FIREBASE_STORAGE_BUCKET=fuelguard-f3112.firebasestorage.app
FIREBASE_API_KEY=AIzaSyCeJl8sXTHZPrq-YPJ1C206fS5UXVcHNFA

# Paste the ENTIRE serviceAccountKey.json as one line (used in Railway / production).
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Then run: python -c "import json,sys; print(json.dumps(json.load(open(sys.argv[1]))))" serviceAccountKey.json
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"fuelguard-f3112","private_key_id":"REPLACE","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-REPLACE@fuelguard-f3112.iam.gserviceaccount.com","client_id":"REPLACE","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"REPLACE"}

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-64-char-random-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email (Gmail App Password recommended) ────────────────────────────────────
# Gmail setup: enable 2FA → Google Account → Security → App Passwords → Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=noreply@fuelguard.com

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10

# ── AI Chatbot (optional) ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Evidence Retention ────────────────────────────────────────────────────────
EVIDENCE_RETENTION_DAYS=90
